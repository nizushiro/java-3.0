ZD22 (HTML!!!!!!!!!!!)
<!-- HTML -->
<label id="username-label">Nazwa użytkownika</label>

<script>
  // 1. Znajdź etykietę (label)
  const label = document.getElementById('username-label');

  // 2. Utwórz nowy element span
  const span = document.createElement('span');

  // 3. Dodaj tekst do span
  span.textContent = ' (Wymagane)';
  
  // Opcjonalnie: dodaj styl, np. kolor czerwony
  span.style.color = 'red';

  // 4. Dołącz span do etykiety
  label.appendChild(span);
</script>


