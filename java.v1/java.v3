ZD18 (HTML!!!!)
<table id="mojaTabela" border="1">
    <thead>
        <tr>
            <th>ID</th>
            <th>Imię</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>101</td>
            <td>Anna</td>
        </tr>
    </tbody>
</table>

<br>
<button onclick="dodajWiersz()">Dodaj Piotra</button>

<script>
    function dodajWiersz() {
        // 1. Pobierz tabelę
        var table = document.getElementById("mojaTabela").getElementsByTagName('tbody')[0];
        
        // 2. Dodaj nowy wiersz na końcu (-1)
        var newRow = table.insertRow(-1);
        
        // 3. Dodaj komórki (komórka 1: ID, komórka 2: Imię)
        var cell1 = newRow.insertCell(0);
        var cell2 = newRow.insertCell(1);
        
        // 4. Wstaw dane do komórek
        cell1.innerHTML = "103";
        cell2.innerHTML = "Piotr";
    }
</script>


